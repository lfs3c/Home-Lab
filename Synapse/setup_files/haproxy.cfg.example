global
    log /dev/log local0
    log /dev/log local1 notice
    daemon
    maxconn 2048

defaults
    log global
    mode http
    option httplog
    option dontlognull
    timeout connect 5s
    timeout client 60s
    timeout server 60s

frontend http_in
    bind *:80
    acl host_root hdr(host) -i example.com
    acl host_matrix hdr(host) -i matrix.example.com

    http-request return status 200 content-type application/json lf-string '{"m.server":"matrix.example.com:443"}' if host_root { path -i /.well-known/matrix/server }
    http-request return status 200 content-type application/json hdr Access-Control-Allow-Origin "*" lf-string '{"m.homeserver":{"base_url":"https://matrix.example.com"}}' if host_root { path -i /.well-known/matrix/client }

    http-request redirect scheme https code 301 if host_root || host_matrix
    default_backend deny_all

frontend https_in
    bind *:443 ssl crt /etc/haproxy/certs/matrix.example.com.pem crt /etc/haproxy/certs/example.com.pem alpn h2,http/1.1
    http-request set-header X-Forwarded-Proto https
    http-request set-header X-Forwarded-For %[src]

    acl host_root hdr(host) -i example.com
    acl host_matrix hdr(host) -i matrix.example.com
    acl matrix_paths path_beg /_matrix /_synapse/client

    http-request return status 200 content-type application/json lf-string '{"m.server":"matrix.example.com:443"}' if host_root { path -i /.well-known/matrix/server }
    http-request return status 200 content-type application/json hdr Access-Control-Allow-Origin "*" lf-string '{"m.homeserver":{"base_url":"https://matrix.example.com"}}' if host_root { path -i /.well-known/matrix/client }

    use_backend synapse_backend if host_matrix matrix_paths
    default_backend deny_all

backend synapse_backend
    server synapse_local 127.0.0.1:8008 check

backend deny_all
    http-request deny deny_status 404
